# ── Database ──────────────────────────────────────────────────────────
# Локально:
DATABASE_URL=postgresql+asyncpg://postgres:postgres@db:5432/nexus
# Railway автоматически подставит DATABASE_URL из своего PostgreSQL сервиса

# ── Redis ─────────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379
# Railway автоматически подставит REDIS_URL

# ── AI ────────────────────────────────────────────────────────────────
GROQ_API_KEY=gsk_your_key_here
GROQ_MODEL=llama-3.3-70b-versatile
GROQ_MODEL_FAST=llama-3.1-8b-instant

# ── Security ──────────────────────────────────────────────────────────
JWT_SECRET=замените-на-случайную-строку-минимум-32-символа
JWT_ALGORITHM=HS256
JWT_EXPIRE_HOURS=72

# ── Frontend URL (для CORS) ───────────────────────────────────────────
# Вставьте ваш Vercel URL после деплоя:
FRONTEND_URL=https://ваш-проект.vercel.app

# ── Telegram (опционально, только если нужна мини-апп) ───────────────
BOT_TOKEN=
ADMIN_TELEGRAM_IDS=
WEBAPP_URL=

# ── App ───────────────────────────────────────────────────────────────
DEBUG=false
